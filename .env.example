# ─────────────────────────────────────────────────────────────────────────────
# Painel de Inteligência Comercial de Eventos — variáveis de ambiente
# Copie para .env.local e preencha. NUNCA comite .env.local nem segredos.
# ─────────────────────────────────────────────────────────────────────────────

# App
APP_URL=http://localhost:3000

# ── Supabase ────────────────────────────────────────────────────────────────
# Públicas (vão para o browser). A anon key respeita RLS.
NEXT_PUBLIC_SUPABASE_URL=https://jpazzkivktidryeieblj.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Privada (NUNCA exposta ao browser). Bypassa RLS — só no backend/jobs.
SUPABASE_URL=https://jpazzkivktidryeieblj.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Schema dedicado deste projeto dentro do banco compartilhado.
SUPABASE_DB_SCHEMA=eventos

# ── Kommo CRM (API v4) ──────────────────────────────────────────────────────
# Apenas backend. O token NUNCA pode ir para o cliente, logs ou banco em texto aberto.
KOMMO_SUBDOMAIN=                       # ex.: minhaconta  (de minhaconta.kommo.com)
KOMMO_API_BASE_URL=                    # ex.: https://minhaconta.kommo.com/api/v4
KOMMO_LONG_LIVED_TOKEN=                # token de integração privada de longa duração
KOMMO_WEBHOOK_SECRET=                  # segredo aleatório usado no caminho do webhook

# ── Jobs / Cron ─────────────────────────────────────────────────────────────
CRON_SECRET=                           # protege as rotas de cron (header Authorization: Bearer)

# ── Observabilidade (opcional) ──────────────────────────────────────────────
SENTRY_DSN=

# ── Timezone de negócio (fechamento diário/mensal) ──────────────────────────
BUSINESS_TIMEZONE=America/Sao_Paulo
